.DS_Store
.env
.env.*
!.env.example

# Codex/Codex CLI (auth/session state must never be committed)
.codex/
auth.json
codex-auth.json
codex.auth.json

__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.venv/
venv/

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.idea/
.vscode/

# Runtime/control-plane state (instance-specific; not a source of truth)
.openteam/state/instance_id
.openteam/state/*.db
.openteam/state/*.db-*
.openteam/state/*.jsonl
.openteam/state/_trash/

# Cluster runtime snapshots (not a source of truth; keep config tracked)
.openteam/cluster/state/*
!.openteam/cluster/state/.gitkeep

# Conversations can contain sensitive free-form content; keep local by default
.openteam/ledger/conversations/

# --- Secrets / credentials (must never be committed) ---
*_token*
*credentials*
.secrets/
secrets/

# SSH keys / certs that may be accidentally copied into the repo
**/.ssh/
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts

*.pem
*.p12
*.pfx
*.key
*.crt
*.cer
*.der
*.jks

# sshpass temp files (avoid accidental check-in)
sshpass*

# Self-improve runtime state (debounce checkpoints; not a source of truth)
.openteam/state/self_improve_last_run.*
.openteam/state/self_improve_state.json
.openteam/state/self_improve_daemon.*

# Common scratch dirs
.tmp/
tmp/

# Backup files created by OpenTeam scripts/migrations (keep local)
*.bak.*

# Local safety snapshots (should not exist for scope=openteam; keep local if present)
docs/product/openteam/requirements/history/
docs/product/openteam/REPO_UNDERSTANDING_*.md
docs/product/openteam/repo_inspect.md
