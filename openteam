#!/usr/bin/env python3
"""OpenTeam CLI entry point.

This is a thin wrapper that delegates to the openteam_cli package.
The original monolithic CLI is preserved in openteam_legacy.py.
"""
import sys
from pathlib import Path

# Ensure repo root is on sys.path
sys.path.insert(0, str(Path(__file__).resolve().parent))

from openteam_cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
