# Runtime env (do not commit real secrets)
#
# Copy to .env and fill required values:
#   cp .env.example .env

# --- Versions (non-secret, pinned for reproducibility) ---
POSTGRESQL_VERSION=16

# --- Postgres (used only when TEAMOS_DB_URL is empty) ---
POSTGRES_DB=team_os
POSTGRES_USER=teamos
POSTGRES_PASSWORD=

# --- Team OS repo path (requirement: default ../team-os) ---
# runtime-init will rewrite this to the absolute team-os repo path for the current machine.
TEAM_OS_REPO_PATH=../team-os
# Docker compose project + volume naming. Override when you want multiple local runtimes.
TEAMOS_DOCKER_PROJECT_NAME=team-os-runtime
TEAMOS_DOCKER_VOLUME_PREFIX=team-os-runtime

# --- Database ---
# Optional shared runtime DB. When set to postgres://..., control-plane connects directly
# to that DB instead of the local postgres container.
TEAMOS_DB_URL=

# --- LLM (required only when calling models) ---
TEAMOS_LLM_API_KEY=
TEAMOS_LLM_BASE_URL=https://openrouter.ai/api/v1
TEAMOS_LLM_MODEL=openrouter/openai/gpt-5.4
TEAMOS_CODEX_MODEL=

# --- Runtime proxy (optional; applies inside control-plane container only) ---
# Docker build does not use these. Use host.docker.internal instead of 127.0.0.1
# so the running container can reach the host proxy.
TEAMOS_RUNTIME_HTTP_PROXY=
TEAMOS_RUNTIME_HTTPS_PROXY=
TEAMOS_RUNTIME_ALL_PROXY=
# Keep internal Docker service names and loopback out of the proxy path.
TEAMOS_RUNTIME_NO_PROXY=localhost,127.0.0.1,host.docker.internal,postgres,openhands-agent-server,control-plane,chatgpt.com,.chatgpt.com,api.openai.com,.openai.com,openrouter.ai,api.openrouter.ai,api.openrouter.com

# --- Build proxy (optional; only for docker build) ---
# Enable these only when image build cannot reach npm/pip/git directly.
TEAMOS_BUILD_HTTP_PROXY=
TEAMOS_BUILD_HTTPS_PROXY=
TEAMOS_BUILD_ALL_PROXY=
TEAMOS_BUILD_NO_PROXY=

# --- GitHub (optional; used for opening issues/PRs) ---
GITHUB_TOKEN=

# --- OpenHands (recommended) ---
# Used by openhands-agent-server. If empty, secrets will not persist across restarts.
OH_SECRET_KEY=

# --- Control Plane ---
# When set to 1, seeds mock agents/runs for demo (safe; no business logic).
TEAMOS_DEMO_SEED=0
# Persist repo-improvement task/proposal ledgers to workspace files as well as RuntimeDB.
TEAMOS_RUNTIME_FILE_MIRROR=1
# Global runtime gate for background workflow loops.
TEAMOS_RUNTIME_WORKFLOW_LOOPS_ENABLED=1
# Cleanup cadence for stale workflow activity bookkeeping.
TEAMOS_RUNTIME_REPO_IMPROVEMENT_CLEANUP_INTERVAL_SEC=60
# TTL for marking stuck repo-improvement runs/agents stale.
TEAMOS_RUNTIME_REPO_IMPROVEMENT_STALE_TTL_SEC=900
# Keep localized natural-language fields in Simplified Chinese by default.
TEAMOS_RUNTIME_LOCALIZE_ZH=1
# Runtime DB path inside container.
TEAMOS_RUNTIME_DB_PATH=/teamos-runtime/state/runtime.db

# --- CrewAI ---
# CrewAI auth mode. oauth_codex uses the local ~/.codex login state.
TEAMOS_CREWAI_AUTH_MODE=oauth_codex
# CrewAI reasoning effort. Upgraded CrewAI accepts xhigh.
TEAMOS_CREWAI_REASONING_EFFORT=xhigh
# When using oauth_codex, temporarily unset proxy vars during model calls to avoid proxy-chain challenge pages.
TEAMOS_CREWAI_DISABLE_PROXY_FOR_OAUTH_CODEX=1
# Disable crewAI telemetry by default for local runtime.
TEAMOS_CREWAI_DISABLE_TELEMETRY=1
# CrewAI package source for image/bootstrap install.
TEAMOS_PYTHON_BASE_IMAGE=python:3.11-slim-bookworm
TEAMOS_CREWAI_GIT_URL=https://github.com/crewAIInc/crewAI.git
TEAMOS_CREWAI_GIT_REF=main

# --- Control Plane Image ---
TEAMOS_CONTROL_PLANE_IMAGE=ghcr.io/wangguanran/teamos-control-plane:main
# When set to 1, a local host-side watcher polls for newer control-plane images and
# recreates the control-plane container when a newer image has been pulled.
TEAMOS_CONTROL_PLANE_AUTO_UPDATE=0
# Poll interval for the local control-plane image watcher.
TEAMOS_CONTROL_PLANE_AUTO_UPDATE_INTERVAL_SEC=300
# When set to 1, only update after /v1/status reports zero active runs.
TEAMOS_CONTROL_PLANE_AUTO_UPDATE_ONLY_IF_IDLE=0

# --- Build ---
TEAMOS_NODE_VERSION=24.12.0
TEAMOS_NODE_DIST_BASE_URL=https://npmmirror.com/mirrors/node
# CI image builds resolve the latest published openclaw version automatically.
# This value only applies to manual image builds.
TEAMOS_OPENCLAW_VERSION=2026.3.2
TEAMOS_NPM_REGISTRY=https://registry.npmmirror.com
# Faster build mirrors for proxy-enabled Docker builds (override if needed).
TEAMOS_APT_MIRROR_URL=https://mirrors.ustc.edu.cn/debian
TEAMOS_APT_SECURITY_MIRROR_URL=https://mirrors.ustc.edu.cn/debian-security
TEAMOS_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
TEAMOS_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# --- OpenClaw reporting (optional) ---
# Requires the runtime image to include the openclaw CLI and the host ~/.openclaw
# config to be mounted read-only into the container.
TEAMOS_OPENCLAW_AUTO=0
TEAMOS_OPENCLAW_INTERVAL_SEC=30
TEAMOS_OPENCLAW_INITIAL_DELAY_SEC=10
TEAMOS_OPENCLAW_CHANNEL=telegram
TEAMOS_OPENCLAW_TARGET=
TEAMOS_OPENCLAW_GATEWAY_MODE=
TEAMOS_OPENCLAW_GATEWAY_URL=
TEAMOS_OPENCLAW_GATEWAY_TOKEN=
TEAMOS_OPENCLAW_GATEWAY_PASSWORD=
TEAMOS_OPENCLAW_GATEWAY_TRANSPORT=direct
TEAMOS_OPENCLAW_STATE_DIR=
TEAMOS_OPENCLAW_CONFIG_DIR=/root/.openclaw
# Leave empty to auto-allow only the Docker-local host.docker.internal bridge route.
TEAMOS_OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
# Use * for all events, or restrict to specific repo paths such as
# scaffolds/runtime/orchestrator/app/** .
TEAMOS_OPENCLAW_PATH_PATTERNS=*
# Comma-separated event globs, for example REPO_IMPROVEMENT_*,RUN_FAILED .
TEAMOS_OPENCLAW_EVENT_TYPES=REPO_IMPROVEMENT_*
TEAMOS_OPENCLAW_EXCLUDE_EVENT_TYPES=
TEAMOS_OPENCLAW_MESSAGE_PREFIX=[TeamOS 上报]

# --- GitHub Projects panel sync (view layer; optional) ---
# Enable background auto-sync (remote writes) only after mapping.yaml is configured.
TEAMOS_PANEL_GH_AUTO_SYNC=0
# Safety gate for any remote writes (manual sync / auto sync). Keep 0 until you explicitly approve.
TEAMOS_PANEL_GH_WRITE_ENABLED=0
# Sync interval (seconds). Recommended 30-60 for "near real-time" board.
TEAMOS_PANEL_GH_SYNC_INTERVAL_SEC=60
# Debounce to avoid too-frequent sync when events burst.
TEAMOS_PANEL_GH_SYNC_DEBOUNCE_SEC=30

# --- Ports (host bindings) ---
CONTROL_PLANE_PORT=8787
OPENHANDS_AGENT_SERVER_PORT=18000
POSTGRES_PORT=15432
