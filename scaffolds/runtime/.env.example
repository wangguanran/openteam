# Runtime env (do not commit real secrets)
#
# Copy to .env and fill required values:
#   cp .env.example .env

# --- Versions (non-secret, pinned for reproducibility) ---
POSTGRESQL_VERSION=16

# --- Postgres (used only when OPENTEAM_DB_URL is empty) ---
POSTGRES_DB=openteam
POSTGRES_USER=openteam
POSTGRES_PASSWORD=

# --- OpenTeam repo path (requirement: default ../openteam) ---
# runtime-init will rewrite this to the absolute openteam repo path for the current machine.
OPENTEAM_REPO_PATH=../openteam
# Docker compose project + volume naming. Override when you want multiple local runtimes.
OPENTEAM_DOCKER_PROJECT_NAME=openteam-runtime
OPENTEAM_DOCKER_VOLUME_PREFIX=openteam-runtime

# --- Database ---
# Optional shared runtime DB. When set to postgres://..., control-plane connects directly
# to that DB instead of the local postgres container.
OPENTEAM_DB_URL=

# --- LLM (required only when calling models) ---
OPENTEAM_LLM_API_KEY=
OPENTEAM_LLM_BASE_URL=https://openrouter.ai/api/v1
OPENTEAM_LLM_MODEL=openrouter/openai/gpt-5.4
OPENTEAM_CODEX_MODEL=

# --- Runtime proxy (optional; applies inside control-plane container only) ---
# Docker build does not use these. Use host.docker.internal instead of 127.0.0.1
# so the running container can reach the host proxy.
OPENTEAM_RUNTIME_HTTP_PROXY=
OPENTEAM_RUNTIME_HTTPS_PROXY=
OPENTEAM_RUNTIME_ALL_PROXY=
# Keep internal Docker service names and loopback out of the proxy path.
OPENTEAM_RUNTIME_NO_PROXY=localhost,127.0.0.1,host.docker.internal,postgres,openhands-agent-server,control-plane,chatgpt.com,.chatgpt.com,api.openai.com,.openai.com,openrouter.ai,api.openrouter.ai,api.openrouter.com

# --- Build proxy (optional; only for docker build) ---
# Enable these only when image build cannot reach npm/pip/git directly.
OPENTEAM_BUILD_HTTP_PROXY=
OPENTEAM_BUILD_HTTPS_PROXY=
OPENTEAM_BUILD_ALL_PROXY=
OPENTEAM_BUILD_NO_PROXY=

# --- GitHub (optional; used for opening issues/PRs) ---
GITHUB_TOKEN=

# --- OpenHands (recommended) ---
# Used by openhands-agent-server. If empty, secrets will not persist across restarts.
OH_SECRET_KEY=

# --- Control Plane ---
# When set to 1, seeds mock agents/runs for demo (safe; no business logic).
OPENTEAM_DEMO_SEED=0
# Persist team workflow task/proposal ledgers to workspace files as well as RuntimeDB.
OPENTEAM_RUNTIME_FILE_MIRROR=1
# Global runtime gate for background workflow loops.
OPENTEAM_RUNTIME_WORKFLOW_LOOPS_ENABLED=1
# Cleanup cadence for stale workflow activity bookkeeping.
OPENTEAM_RUNTIME_TEAM_WORKFLOW_CLEANUP_INTERVAL_SEC=60
# TTL for marking stuck team workflow runs/agents stale.
OPENTEAM_RUNTIME_TEAM_WORKFLOW_STALE_TTL_SEC=900
# Keep localized natural-language fields in Simplified Chinese by default.
OPENTEAM_RUNTIME_LOCALIZE_ZH=1
# Runtime DB path inside container.
OPENTEAM_RUNTIME_DB_PATH=/openteam-runtime/state/runtime.db

# --- CrewAI ---
# CrewAI auth mode. oauth_codex uses the local ~/.codex login state.
OPENTEAM_CREWAI_AUTH_MODE=oauth_codex
# CrewAI reasoning effort. Upgraded CrewAI accepts xhigh.
OPENTEAM_CREWAI_REASONING_EFFORT=xhigh
# When using oauth_codex, temporarily unset proxy vars during model calls to avoid proxy-chain challenge pages.
OPENTEAM_CREWAI_DISABLE_PROXY_FOR_OAUTH_CODEX=1
# Disable crewAI telemetry by default for local runtime.
OPENTEAM_CREWAI_DISABLE_TELEMETRY=1
# CrewAI package source for image/bootstrap install.
OPENTEAM_PYTHON_BASE_IMAGE=python:3.11-slim-bookworm
OPENTEAM_CREWAI_GIT_URL=https://github.com/crewAIInc/crewAI.git
OPENTEAM_CREWAI_GIT_REF=main

# --- Control Plane Image ---
OPENTEAM_CONTROL_PLANE_IMAGE=ghcr.io/openteam-dev/openteam-control-plane:main
# When set to 1, a local host-side watcher polls for newer control-plane images and
# recreates the control-plane container when a newer image has been pulled.
OPENTEAM_CONTROL_PLANE_AUTO_UPDATE=0
# Poll interval for the local control-plane image watcher.
OPENTEAM_CONTROL_PLANE_AUTO_UPDATE_INTERVAL_SEC=300
# When set to 1, only update after /v1/status reports zero active runs.
OPENTEAM_CONTROL_PLANE_AUTO_UPDATE_ONLY_IF_IDLE=0

# --- Build ---
OPENTEAM_NODE_VERSION=24.12.0
OPENTEAM_NODE_DIST_BASE_URL=https://npmmirror.com/mirrors/node
# CI image builds resolve the latest published openclaw version automatically.
# This value only applies to manual image builds.
OPENTEAM_OPENCLAW_VERSION=2026.3.2
OPENTEAM_NPM_REGISTRY=https://registry.npmmirror.com
# Faster build mirrors for proxy-enabled Docker builds (override if needed).
OPENTEAM_APT_MIRROR_URL=https://mirrors.ustc.edu.cn/debian
OPENTEAM_APT_SECURITY_MIRROR_URL=https://mirrors.ustc.edu.cn/debian-security
OPENTEAM_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
OPENTEAM_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# --- OpenClaw reporting (optional) ---
# Requires the runtime image to include the openclaw CLI and the host ~/.openclaw
# config to be mounted read-only into the container.
OPENTEAM_OPENCLAW_AUTO=0
OPENTEAM_OPENCLAW_INTERVAL_SEC=30
OPENTEAM_OPENCLAW_INITIAL_DELAY_SEC=10
OPENTEAM_OPENCLAW_CHANNEL=telegram
OPENTEAM_OPENCLAW_TARGET=
OPENTEAM_OPENCLAW_GATEWAY_MODE=
OPENTEAM_OPENCLAW_GATEWAY_URL=
OPENTEAM_OPENCLAW_GATEWAY_TOKEN=
OPENTEAM_OPENCLAW_GATEWAY_PASSWORD=
OPENTEAM_OPENCLAW_GATEWAY_TRANSPORT=direct
OPENTEAM_OPENCLAW_STATE_DIR=
OPENTEAM_OPENCLAW_CONFIG_DIR=/root/.openclaw
# Leave empty to auto-allow only the Docker-local host.docker.internal bridge route.
OPENTEAM_OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
# Use * for all events, or restrict to specific repo paths such as
# scaffolds/runtime/orchestrator/app/** .
OPENTEAM_OPENCLAW_PATH_PATTERNS=*
# Comma-separated event globs, for example TEAM_*,RUN_FAILED .
OPENTEAM_OPENCLAW_EVENT_TYPES=TEAM_*
OPENTEAM_OPENCLAW_EXCLUDE_EVENT_TYPES=
OPENTEAM_OPENCLAW_MESSAGE_PREFIX=[OpenTeam 上报]

# --- GitHub Projects panel sync (view layer; optional) ---
# Enable background auto-sync (remote writes) only after mapping.yaml is configured.
OPENTEAM_PANEL_GH_AUTO_SYNC=0
# Safety gate for any remote writes (manual sync / auto sync). Keep 0 until you explicitly approve.
OPENTEAM_PANEL_GH_WRITE_ENABLED=0
# Sync interval (seconds). Recommended 30-60 for "near real-time" board.
OPENTEAM_PANEL_GH_SYNC_INTERVAL_SEC=60
# Debounce to avoid too-frequent sync when events burst.
OPENTEAM_PANEL_GH_SYNC_DEBOUNCE_SEC=30

# --- Ports (host bindings) ---
CONTROL_PLANE_PORT=8787
OPENHANDS_AGENT_SERVER_PORT=18000
POSTGRES_PORT=15432
