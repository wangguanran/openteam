{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team OS Project Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origin_url": {
          "type": "string"
        },
        "default_branch": {
          "type": "string"
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "project_url": {
          "type": "string"
        }
      }
    },
    "teams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
      },
      "patternProperties": {
        "^[A-Za-z0-9_-]+(?:-[A-Za-z0-9_-]+)*$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "workflow_settings": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "disabled_reason": {
                    "type": "string"
                  },
                  "max_candidates": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "active_window_start_hour": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 23
                  },
                  "active_window_end_hour": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 24
                  },
                  "max_continuous_runtime_minutes": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dormant_after_zero_scans": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
