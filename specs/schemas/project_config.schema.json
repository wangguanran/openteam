{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team OS Project Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origin_url": {
          "type": "string"
        },
        "default_branch": {
          "type": "string"
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "project_url": {
          "type": "string"
        }
      }
    },
    "repo_improvement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_settings": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "disabled_reason": {
                "type": "string"
              },
              "max_candidates": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
