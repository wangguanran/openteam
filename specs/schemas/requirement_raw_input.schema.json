{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenTeam Requirement Raw Input (v3 Raw-First, user-only)",
  "type": "object",
  "additionalProperties": false,
  "required": ["raw_id", "timestamp", "scope", "user", "channel", "text", "text_sha256"],
  "properties": {
    "raw_id": {
      "type": "string",
      "minLength": 8,
      "description": "Deterministic raw input id (stable for this record)."
    },
    "timestamp": {
      "type": "string",
      "description": "UTC ISO-8601 timestamp, e.g. 2026-02-16T00:39:59Z"
    },
    "scope": {
      "type": "string",
      "description": "openteam | project:<project_id>"
    },
    "user": {
      "type": "string",
      "description": "User identifier (do not include secrets)."
    },
    "channel": {
      "type": "string",
      "description": "Input channel",
      "enum": ["cli", "api", "chat", "import"]
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "description": "Raw requirement text (verbatim)."
    },
    "text_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "sha256 of raw text, hex lowercase."
    }
  }
}
