# OpenTeam Project Config (Workspace-local; do NOT commit into repos)
#
# Managed by OpenTeam deterministic pipelines:
# - show:      openteam project config show --project {{PROJECT_ID}}
# - set:       openteam project config set --project {{PROJECT_ID}} --key <...> --value <...>
# - validate:  openteam project config validate --project {{PROJECT_ID}}
#
# Notes:
# - This file lives under: ~/.openteam/workspace/projects/{{PROJECT_ID}}/state/config/project.yaml
# - Project truth sources (requirements/ledgers/logs/prompts) live under `state/`.

schema_version: 1
project_id: "{{PROJECT_ID}}"

repo:
  origin_url: ""
  default_branch: ""

prompt:
  enabled: true

panel:
  enabled: true
  project_url: ""

teams: {}

notes: ""
